        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{ $('Parse WhatsApp Payload').item.json.phone }}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"¡Hola! Claro que sí, con gusto le ayudamos con eso. Para darle una cotización exacta, ¿podría enviarme las medidas aproximadas o fotos del área donde necesita el trabajo? Así le pasamos un presupuesto de una vez.\"\n  }\n}",
