    {
      "parameters": {
        "jsCode": "// Handle both raw body wrapper and direct JSON modes\nconst raw = $input.first().json;\nconst body = raw.body ?? raw;\n\n// Handle Meta verification GET requests\nif (!body || !body.entry) {\n  return [{ json: { skip: true } }];\n}\n\nconst entry = body.entry[0];\n\n// entry[0] might be an array in some test payloads — unwrap it\nconst entryObj = Array.isArray(entry) ? entry[0] : entry;\nconst change = entryObj.changes[0].value;\n\n// Only process actual messages\nif (!change.messages) {\n  return [{ json: { skip: true } }];\n}\n\nconst phone = change.contacts?.[0]?.wa_id \n           || change.messages?.[0]?.from \n           || '';\nconst name  = change.contacts?.[0]?.profile?.name || 'Cliente';\nconst message = change.messages[0].text?.body || '';\n\n// Safety check — if phone is empty, skip to avoid bad API call\nif (!phone) {\n  return [{ json: { skip: true, reason: 'no phone extracted' } }];\n}\n\nreturn [{ json: { phone, name, message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
